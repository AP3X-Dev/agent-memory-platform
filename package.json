{
  "name": "memberry",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/neo4j",
    "packages/redis",
    "packages/mcp",
    "packages/research",
    "packages/arch",
    "packages/code",
    "packages/retrieval",
    "packages/wiki",
    "packages/graph"
  ],
  "scripts": {
    "build": "node scripts/clean-build-artifacts.mjs && tsc -b tsconfig.build.json",
    "test": "npm run build && npm run test --workspaces --if-present",
    "dev": "tsx packages/mcp/src/server.ts",
    "setup": "bash scripts/setup.sh",
    "smoke": "node scripts/smoke.mjs",
    "start": "tsx packages/mcp/src/server.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "vite": "^6.4.2"
  },
  "dependencies": {
    "tsx": "^4.0.0"
  }
}
