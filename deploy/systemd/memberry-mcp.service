[Unit]
Description=MemBerry MCP Server
After=network.target docker.service

[Service]
Type=simple
User=cerebro
WorkingDirectory=/home/cerebro/projects/amp
ExecStart=/usr/bin/npx tsx packages/mcp/src/server.ts
Restart=always
RestartSec=5
EnvironmentFile=/etc/memberry/env
Environment=NODE_ENV=production
Environment=MEMBERRY_EXPORT_PATH=/home/cerebro/projects/amp/.memberry
Environment=MCP_PORT=3101
Environment=HOST=0.0.0.0

[Install]
WantedBy=multi-user.target
