# Neo4j — managed by docker-compose.yml (amp-neo4j container)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Redis — shared from ~/infra (cerebro-redis), no auth
REDIS_URL=redis://localhost:6379

# OpenAI — used for embeddings (text-embedding-3-small) and entity extraction
OPENAI_API_KEY=

# Export directory for amp_compile and amp_ingest
AMP_EXPORT_PATH=./.amp

# MCP server port (SSE transport)
MCP_PORT=3101

# API token for authenticated MCP access (optional — set AMP_ALLOW_UNAUTHENTICATED=1 to skip)
AMP_API_TOKEN=
AMP_ALLOW_UNAUTHENTICATED=

# Restrict amp_ingest source_path and amp_compile output_dir to this directory (default: cwd)
AMP_INGEST_ALLOW_DIR=

# Set to 1 to run live OpenAI embedding tests (costs API credits)
RUN_LIVE_TESTS=
